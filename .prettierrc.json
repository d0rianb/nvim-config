{
    "semi": false,
    "singleQuote": true,
    "trailingComma": "es5",
    "bracketSameLine": true,
    "arrowParens": "avoid",
    "proseWrap": "preserve",
    "printWidth": 150,
    "embeddedLanguageFormatting": "auto",

    "overrides": [
        {
            "files": ".prettierrc",
            "options": {
                "parser": "json",
                "tabWidth": 2
            }
        }
    ]
}
